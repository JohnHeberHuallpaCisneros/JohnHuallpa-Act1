using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace ACT4_3
{
    class P3
    {
        static void Main()
        {
            int acumulador = 0;
            int valor;

            while (true)
            {
                valor = ReadInt("ingresa algun valor (con 9999 finaliza el programa): ");
                if (valor == 9999)
                {
                    break;
                }
                acumulador += valor;
            }
            Console.WriteLine("valor acumulado= " + acumulador);
            if (acumulador > 0)
                Console.WriteLine("El valor es mayor a 0");
            else if (acumulador < 0)
                Console.WriteLine("El valor es menor a 0");
            else
                Console.WriteLine("el valor es 0");
        }

        static int ReadInt(string prompt)
        {
            while (true)
            {
                Console.Write(prompt);
                string? line = Console.ReadLine();
                if (line is null)
                {
                    Console.WriteLine("Entrada nula. Intente de nuevo.");
                    continue;
                }
                if (int.TryParse(line, out int value))
                    return value;
                Console.WriteLine("Entrada no válida. Ingrese un número entero.");
            }
        }
    }
}